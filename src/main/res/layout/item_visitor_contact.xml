<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/visitor_contact_item_background"
    android:orientation="vertical"
    android:padding="18dp">

    <TextView
        android:id="@+id/contactTitle"
        style="@style/VisitorContactTitleText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />

    <TextView
        android:id="@+id/contactAvailability"
        style="@style/VisitorContactBadgeText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/visitor_spacing_sm" />

    <TextView
        android:id="@+id/contactChannels"
        style="@style/VisitorContactMetaText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp" />

</LinearLayout>
