<resources>

    <!-- Base application theme. -->
    <style name="AppTheme" parent="Theme.AppCompat.Light.NoActionBar"> </style>

    <style name="AppTheme.AppBarOverlay" parent="ThemeOverlay.AppCompat.Dark.ActionBar" />

    <style name="AppTheme.PopupOverlay" parent="ThemeOverlay.AppCompat.Light" />

    <style name="VisitorTitleText">
        <item name="android:textColor">@color/visitorTextPrimary</item>
        <item name="android:textSize">32sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="VisitorSubtitleText">
        <item name="android:textColor">@color/visitorTextSecondary</item>
        <item name="android:textSize">22sp</item>
    </style>

    <style name="VisitorBodyText">
        <item name="android:textColor">@color/visitorTextPrimary</item>
        <item name="android:textSize">18sp</item>
    </style>

    <style name="VisitorPrimaryButton">
        <item name="android:background">@drawable/visitor_primary_button</item>
        <item name="android:gravity">center</item>
        <item name="android:minHeight">@dimen/visitor_button_height</item>
        <item name="android:minWidth">280dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textColor">@color/colorWhite</item>
        <item name="android:textSize">19sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:paddingLeft">24dp</item>
        <item name="android:paddingRight">24dp</item>
    </style>

    <style name="VisitorSecondaryButton">
        <item name="android:background">@drawable/visitor_secondary_button</item>
        <item name="android:gravity">center</item>
        <item name="android:minHeight">@dimen/visitor_button_height</item>
        <item name="android:minWidth">280dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textColor">@color/colorPrimaryDark</item>
        <item name="android:textSize">18sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:paddingLeft">24dp</item>
        <item name="android:paddingRight">24dp</item>
    </style>

    <style name="VisitorBadgeText">
        <item name="android:background">@drawable/visitor_badge_background</item>
        <item name="android:paddingLeft">12dp</item>
        <item name="android:paddingTop">6dp</item>
        <item name="android:paddingRight">12dp</item>
        <item name="android:paddingBottom">6dp</item>
        <item name="android:textColor">@color/visitorBadgeMutedText</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="VisitorContactBadgeText" parent="VisitorBadgeText">
        <item name="android:textColor">@color/visitorBadgeMutedText</item>
    </style>

    <style name="VisitorContactTitleText">
        <item name="android:textColor">@color/visitorTextPrimary</item>
        <item name="android:textSize">22sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="VisitorContactMetaText">
        <item name="android:textColor">@color/visitorTextSecondary</item>
        <item name="android:textSize">16sp</item>
    </style>

</resources>
