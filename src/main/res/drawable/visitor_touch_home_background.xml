<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="315"
                android:startColor="@color/visitorHeroBackgroundStart"
                android:centerColor="@color/visitorHeroBackgroundCenter"
                android:endColor="@color/visitorHeroBackgroundEnd" />
        </shape>
    </item>

    <item android:gravity="center">
        <shape android:shape="oval">
            <size
                android:width="900dp"
                android:height="900dp" />
            <solid android:color="@color/visitorHeroGlow" />
        </shape>
    </item>
</layer-list>
