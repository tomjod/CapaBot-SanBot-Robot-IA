VISITOR_NOTIFY_CONTACTS_PATH=backend/tests/fixtures/contacts.json

# Telegram bot delivery
VISITOR_NOTIFY_TELEGRAM_BOT_TOKEN=
VISITOR_NOTIFY_TELEGRAM_API_BASE_URL=https://api.telegram.org
VISITOR_NOTIFY_TELEGRAM_TIMEOUT_SECONDS=10

# Mailtrap email delivery
VISITOR_NOTIFY_EMAIL_MAILTRAP_TOKEN=
VISITOR_NOTIFY_EMAIL_FROM=
VISITOR_NOTIFY_EMAIL_FROM_NAME=CapaBot

# Legacy SMTP fallback is still supported for backward compatibility.
# VISITOR_NOTIFY_EMAIL_SMTP_HOST=
# VISITOR_NOTIFY_EMAIL_SMTP_PORT=25
# VISITOR_NOTIFY_EMAIL_TIMEOUT_SECONDS=10

# Keep false in operational environments; set true only for local seam testing.
VISITOR_NOTIFY_ALLOW_STUB_DELIVERY=false
